<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MRC · {{EA_NAME}} Dashboard</title>

<!--
  ┌─────────────────────────────────────────────────────────────┐
  │  SPINE — do not edit config here.                           │
  │  Edit your rib in ribs/<yourname>.yaml then rebuild:        │
  │  say "rebuild dashboard" in Cowork                          │
  └─────────────────────────────────────────────────────────────┘
-->

<!-- __RIB_INJECT__ -->

<style>
:root {
  color-scheme: light;
  --navy:#002D74;--navy-mid:#22438a;--navy-light:#e8eef7;
  --surface:#f8f9ff;--white:#ffffff;--ink:#0b1c30;--muted:#444651;--faint:#747782;
  --border:#c4c6d2;--border-lt:#dce9ff;
  --zoom-bg:#e8f0fe;--zoom-fg:#1a73e8;
  --ip-bg:#e8f5e9;--ip-fg:#2e7d32;
  --pers-bg:#f3e8fd;--pers-fg:#7b1fa2;
  --warn:#ba1a1a;
  --font-serif:Georgia,'Times New Roman',serif;
  --font-sans:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--surface);color:var(--ink);font-family:var(--font-sans);font-size:13px;line-height:1.4;}
.hdr{background:var(--navy);color:white;padding:14px 20px 0;position:sticky;top:0;z-index:20;}
.hdr-top{display:flex;align-items:baseline;gap:10px;margin-bottom:10px;}
.hdr h1{font-family:var(--font-serif);font-size:16px;font-weight:600;letter-spacing:-0.01em;}
.hdr-sub{font-size:10px;opacity:.55;text-transform:uppercase;letter-spacing:.1em;}
.hdr-date{margin-left:auto;font-size:10px;opacity:.6;}
.cal-bar{display:flex;gap:6px;padding:8px 20px;background:var(--navy);border-top:1px solid rgba(255,255,255,.1);flex-wrap:wrap;}
.cal-bar.single{display:none;}
.cal-chip{font-size:10px;font-weight:600;padding:3px 10px;border-radius:999px;border:1.5px solid rgba(255,255,255,.3);color:rgba(255,255,255,.5);cursor:pointer;transition:all .15s;text-transform:uppercase;letter-spacing:.06em;}
.cal-chip.active{color:white;background:rgba(255,255,255,.12);}
.tabs{display:flex;}
.tab-btn{padding:8px 14px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.45);background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:color .15s,border-color .15s;}
.tab-btn:hover{color:rgba(255,255,255,.75);}
.tab-btn.active{color:white;border-bottom-color:white;}
.loading{display:flex;align-items:center;justify-content:center;height:200px;color:var(--faint);gap:8px;}
.spinner{width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--navy);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.err{padding:30px;color:var(--warn);text-align:center;font-size:12px;}
.panel{display:none;}.panel.active{display:block;}
.sched-wrap{padding:14px 18px 40px;}
.day-block{margin-bottom:22px;}
.day-hdr{display:flex;align-items:center;gap:8px;padding-bottom:7px;border-bottom:1.5px solid var(--border);margin-bottom:9px;}
.day-hdr.today{border-bottom-color:var(--navy);}
.day-name{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--faint);min-width:28px;}
.day-hdr.today .day-name,.day-hdr.today .day-num{color:var(--navy);}
.day-num{font-family:var(--font-serif);font-size:20px;font-weight:600;color:var(--ink);line-height:1;}
.today-chip{font-size:9px;font-weight:700;background:var(--navy);color:white;padding:2px 7px;border-radius:999px;text-transform:uppercase;letter-spacing:.06em;}
.sec-label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--faint);margin:0 0 6px;}
.win-row{display:flex;align-items:center;gap:8px;padding:5px 8px;background:#eef2fc;border:1px dashed #b0c4f0;border-radius:4px;margin-bottom:5px;font-size:11px;color:var(--navy-mid);}
.win-row .dur{margin-left:auto;opacity:.5;font-size:10px;}
.evt{display:flex;gap:9px;padding:7px 9px;background:var(--white);border:1px solid var(--border-lt);border-left:3px solid var(--border);border-radius:0 4px 4px 0;margin-bottom:5px;cursor:pointer;transition:background .1s;}
.evt:hover,.evt.selected-evt{background:var(--navy-light);}
.evt-time{min-width:68px;font-size:11px;color:var(--faint);padding-top:1px;font-variant-numeric:tabular-nums;flex-shrink:0;}
.evt-time.allday{font-style:italic;color:var(--border);}
.evt-body{flex:1;min-width:0;}
.evt-title{font-size:12px;font-weight:500;color:var(--ink);line-height:1.35;}
.badge{display:inline-block;font-size:9px;font-weight:700;padding:1px 6px;border-radius:999px;text-transform:uppercase;letter-spacing:.05em;margin-top:3px;}
.badge.zoom{background:var(--zoom-bg);color:var(--zoom-fg);}
.badge.inperson{background:var(--ip-bg);color:var(--ip-fg);}
.badge.personal{background:var(--pers-bg);color:var(--pers-fg);}
.cal-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:4px;vertical-align:middle;}
.evt-loc{font-size:10px;color:var(--faint);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.evt-loc a{color:var(--zoom-fg);text-decoration:none;}
.conflict-flag{font-size:9px;color:var(--warn);font-weight:600;margin-top:2px;text-transform:uppercase;letter-spacing:.05em;}
.no-mtgs{font-size:11px;color:var(--border);font-style:italic;padding:4px 0;}
.radar-wrap{display:grid;grid-template-columns:1fr 260px;height:calc(100vh - 86px);}
.radar-canvas-wrap{position:relative;background:var(--white);border-right:1px solid var(--border-lt);overflow:hidden;}
#radar-canvas{display:block;width:100%;height:100%;}
.radar-hint{position:absolute;bottom:10px;left:0;right:0;text-align:center;font-size:10px;color:var(--border);pointer-events:none;}
.radar-panel{padding:14px;overflow-y:auto;background:var(--surface);}
.radar-empty{display:flex;align-items:center;justify-content:center;height:140px;text-align:center;color:var(--faint);font-size:12px;line-height:1.6;}
.contact-card h3{font-family:var(--font-serif);font-size:15px;font-weight:600;margin-bottom:3px;}
.contact-meta{font-size:11px;color:var(--faint);margin-bottom:12px;}
.contact-stat{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border-lt);}
.contact-stat:last-of-type{border-bottom:none;}
.stat-label{font-size:11px;color:var(--muted);}.stat-val{font-size:13px;font-weight:600;}
.mtg-list{margin-top:12px;}.mtg-item{padding:5px 0;border-bottom:1px solid var(--border-lt);font-size:11px;}
.mtg-item:last-child{border-bottom:none;}.mtg-date{color:var(--faint);font-size:10px;margin-bottom:1px;}
.radar-loading{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:var(--white);flex-direction:column;gap:8px;font-size:12px;color:var(--faint);}
.prep-wrap{padding:14px 18px 40px;}
.prep-empty{display:flex;align-items:center;justify-content:center;height:140px;color:var(--faint);font-size:12px;text-align:center;line-height:1.6;}
.prep-card{background:var(--white);border:1px solid var(--border-lt);border-radius:4px;padding:12px;margin-bottom:10px;}
.prep-card h3{font-family:var(--font-serif);font-size:14px;margin-bottom:6px;}
.prep-row{display:flex;gap:8px;align-items:flex-start;margin-bottom:5px;font-size:12px;}
.prep-label{color:var(--faint);min-width:56px;flex-shrink:0;font-size:11px;padding-top:1px;}
.prep-upcoming h4{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--faint);margin-bottom:8px;}
.prep-evt-btn{display:block;width:100%;text-align:left;padding:7px 10px;background:var(--white);border:1px solid var(--border-lt);border-radius:4px;margin-bottom:5px;cursor:pointer;font-family:var(--font-sans);transition:background .1s;}
.prep-evt-btn:hover,.prep-evt-btn.active{background:var(--navy-light);border-color:var(--navy);}
.prep-evt-title{font-size:12px;font-weight:500;color:var(--ink);}
.prep-evt-time{font-size:10px;color:var(--faint);margin-top:1px;}
</style>
</head>
<body>
<div class="hdr">
  <div class="hdr-top">
    <h1 id="hdr-name">MRC · Schedule</h1>
    <span class="hdr-sub">Executive Intelligence</span>
    <span class="hdr-date" id="hdr-date"></span>
  </div>
  <div class="cal-bar" id="cal-bar"></div>
  <div class="tabs" id="tabs"></div>
</div>
<div class="panel active" id="tab-schedule"><div id="sched-app"><div class="loading"><div class="spinner"></div> Pulling calendar…</div></div></div>
<div class="panel" id="tab-radar">
  <div class="radar-wrap">
    <div class="radar-canvas-wrap">
      <canvas id="radar-canvas"></canvas>
      <div id="radar-loading" class="radar-loading"><div class="spinner"></div> Building relationship map…</div>
      <div class="radar-hint">Click a contact · Drag to rearrange</div>
    </div>
    <div class="radar-panel" id="radar-panel"><div class="radar-empty">Click a contact<br>to view meeting history</div></div>
  </div>
</div>
<div class="panel" id="tab-prep"><div class="prep-wrap" id="prep-app"><div class="loading"><div class="spinner"></div> Loading…</div></div></div>

<script>
// ═══════════════════════════════════════════════════════════════
// SPINE — reads window.__RIB__ for all config. No EA values here.
// ═══════════════════════════════════════════════════════════════
const RIB=window.__RIB__||{};
// viewer: 'ea' = EA managing exec | 'exec' = exec viewing own schedule
const viewer=RIB.viewer||'ea';
const MONTHS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const DAYS=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const DAY_FULL=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const MON_IDX={Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
const OUTLOOK='mcp__4232ebbc-c694-4895-9b33-f52a55fd5c09__list-events';
const SEARCH_EMAILS='mcp__4232ebbc-c694-4895-9b33-f52a55fd5c09__search-emails';
const pad2=n=>String(n).padStart(2,'0');
const toDS=d=>`${d.getFullYear()}-${pad2(d.getMonth()+1)}-${pad2(d.getDate())}`;
const now=new Date(),todayStr=toDS(now);

// Hash state — tab + calendar visibility persisted across reloads
function readHash(){const h=location.hash.slice(1);const p=Object.fromEntries(h.split('&').filter(Boolean).map(s=>s.split('=')));return{tab:p.tab||'schedule',hidden:p.hidden?p.hidden.split(','):[]};}
function writeHash(s){const pts=[`tab=${s.tab}`];if(s.hidden.length)pts.push(`hidden=${s.hidden.join(',')}`);location.hash=pts.join('&');}
let hashState=readHash();

const calendars=RIB.calendars||[];
const features=RIB.features||{schedule:true,radar:false,prep:true};
const daysAhead=RIB.settings?.days_ahead||14;

function isVisible(cal){const inHidden=hashState.hidden.includes(cal.id);return cal.default_visible?!inHidden:inHidden;}
function toggleCal(id){const cal=calendars.find(c=>c.id===id);if(!cal)return;const vis=isVisible(cal);if(vis){if(cal.default_visible){if(!hashState.hidden.includes(id))hashState.hidden.push(id);}else{hashState.hidden=hashState.hidden.filter(h=>h!==id);}}else{if(!cal.default_visible){if(!hashState.hidden.includes(id))hashState.hidden.push(id);}else{hashState.hidden=hashState.hidden.filter(h=>h!==id);}}writeHash(hashState);updateCalChips();renderSchedule();}

// Header — viewer-aware
const firstCalLabel=calendars[0]?.label||'';
document.getElementById('hdr-name').textContent=viewer==='exec'
  ? (firstCalLabel||'My Schedule')
  : (RIB.ea?.name?.split(' ')[0]||'MRC')+' · Schedule';
document.getElementById('hdr-date').textContent=`${DAY_FULL[now.getDay()]}, ${MONTHS[now.getMonth()]} ${now.getDate()}`;

// Calendar chips
const calBar=document.getElementById('cal-bar');
if(calendars.length<=1){calBar.classList.add('single');}
else{calendars.forEach(cal=>{const chip=document.createElement('button');chip.className='cal-chip'+(isVisible(cal)?' active':'');chip.id=`chip-${cal.id}`;chip.textContent=cal.label;if(isVisible(cal))chip.style.borderColor=cal.color;chip.addEventListener('click',()=>toggleCal(cal.id));calBar.appendChild(chip);});}
function updateCalChips(){calendars.forEach(cal=>{const chip=document.getElementById(`chip-${cal.id}`);if(!chip)return;const vis=isVisible(cal);chip.classList.toggle('active',vis);chip.style.borderColor=vis?cal.color:'';});}

// Tabs
const tabDefs=[{id:'schedule',label:'Schedule',on:features.schedule!==false},{id:'radar',label:'Radar',on:!!features.radar},{id:'prep',label:'Prep',on:features.prep!==false}];
const tabsEl=document.getElementById('tabs');
tabDefs.filter(t=>t.on).forEach(t=>{const btn=document.createElement('button');btn.className='tab-btn'+(t.id===hashState.tab?' active':'');btn.dataset.tab=t.id;btn.textContent=t.label;btn.addEventListener('click',()=>switchTab(t.id));tabsEl.appendChild(btn);});

let activeTab=hashState.tab,radarInited=false,prepInited=false;
function switchTab(t){activeTab=t;hashState.tab=t;writeHash(hashState);document.querySelectorAll('.tab-btn').forEach(b=>b.classList.toggle('active',b.dataset.tab===t));document.querySelectorAll('.panel').forEach(p=>p.classList.toggle('active',p.id===`tab-${t}`));if(t==='radar'&&!radarInited){radarInited=true;initRadar();}if(t==='prep'&&!prepInited){prepInited=true;initPrep();}}
document.querySelectorAll('.panel').forEach(p=>p.classList.toggle('active',p.id===`tab-${activeTab}`));

// Calendar fetch cache
let calCache={},calLoading={},allEvents=[];
async function fetchCal(cal){
  if(calCache[cal.id])return calCache[cal.id];
  if(calLoading[cal.id])return calLoading[cal.id];
  const s=new Date(now);s.setHours(0,0,0,0);const e=new Date(s);e.setDate(s.getDate()+daysAhead);
  calLoading[cal.id]=window.cowork.callMcpTool(OUTLOOK,{accountId:cal.accountId,startDate:`${toDS(s)}T00:00:00`,endDate:`${toDS(e)}T23:59:59`,count:50}).then(res=>{const evts=res.isError?[]:parseEvents(res.content[0].text,cal);calCache[cal.id]=evts;return evts;});
  return calLoading[cal.id];
}
async function loadVisibleCals(){const vis=calendars.filter(c=>isVisible(c));const r=await Promise.all(vis.map(fetchCal));allEvents=r.flat();return allEvents;}

// Parser
function parseEvents(text,cal){
  const events=[],yr=now.getFullYear(),blocks=text.split(/\n(?=\d+\.\s)/);
  const pkw=(cal.personal_keywords||[]).map(k=>k.toLowerCase());
  for(const blk of blocks){
    const lines=blk.split('\n').map(l=>l.trim()).filter(Boolean);if(lines.length<2)continue;
    const tm=lines[0].match(/^\d+\.\s+(.+)$/);if(!tm)continue;
    const title=tm[1],dtL=lines[1];let ds=null,st=null,et=null,allDay=false;
    const t2=dtL.match(/(\w{3}),\s+(\w{3})\s+(\d+)\s+·\s+(\d+):(\d+)\s+(AM|PM)(?:\s+\([^)]*\))?\s+[–\-]\s+(\d+):(\d+)\s+(AM|PM)/);
    const ad=dtL.match(/(\w{3}),\s+(\w{3})\s+(\d+)(?:\s+[–\-]\s+\w+,\s+\w+\s+\d+)?\s+\(All day\)/);
    if(t2){const[,,mon,day,sh,sm,sa,eh,em,ea]=t2;ds=toDS(new Date(yr,MON_IDX[mon],parseInt(day)));let h=parseInt(sh);if(sa==='PM'&&h!==12)h+=12;if(sa==='AM'&&h===12)h=0;st=`${pad2(h)}:${sm}`;let eh2=parseInt(eh);if(ea==='PM'&&eh2!==12)eh2+=12;if(ea==='AM'&&eh2===12)eh2=0;et=`${pad2(eh2)}:${em}`;}
    else if(ad){const[,,mon,day]=ad;ds=toDS(new Date(yr,MON_IDX[mon],parseInt(day)));allDay=true;}
    else continue;
    let loc=null,zoom=null;
    for(const ln of lines.slice(2)){if(ln.startsWith('Location:')){loc=ln.slice(9).trim();const z=loc.match(/https?:\/\/[^\s]*zoom[^\s]*/i);if(z)zoom=z[0];}}
    const tl=title.toLowerCase(),ll=(loc||'').toLowerCase();
    let type='business';
    if(pkw.some(w=>tl.includes(w)))type='personal';
    else if(zoom||ll.includes('zoom.us'))type='zoom';
    else if(loc&&(loc.match(/\d{3,}/)||ll.includes('office')||ll.includes(' rd')||ll.includes('blvd')||ll.includes('ave,')||ll.includes('suite')))type='inperson';
    events.push({title,dateStr:ds,startTime:st,endTime:et,isAllDay:allDay,location:loc,zoomUrl:zoom,type,calId:cal.id,calColor:cal.color});
  }
  return events;
}

const fmtT=t=>{if(!t)return'';const[h,m]=t.split(':').map(Number);const ap=h>=12?'pm':'am',h12=h%12||12;return m===0?`${h12}${ap}`:`${h12}:${pad2(m)}${ap}`;};
const toM=t=>{const[h,m]=t.split(':').map(Number);return h*60+m;};
const mts=m=>{const h=Math.floor(m/60),mn=m%60,ap=h>=12?'pm':'am',h12=h%12||12;return mn===0?`${h12}${ap}`:`${h12}:${pad2(mn)}${ap}`;};
const dur=m=>{const h=Math.floor(m/60),mn=m%60;return h>0&&mn>0?`${h}h ${mn}m`:h>0?`${h}h`:`${mn}m`;};
function openWins(evs,cal){const ws=cal?toM(cal.schedule_window?.start||'11:00'):660;const we=cal?toM(cal.schedule_window?.end||'18:00'):1080;const busy=evs.filter(e=>!e.isAllDay&&e.startTime&&e.type!=='personal').map(e=>({s:toM(e.startTime),e:toM(e.endTime||e.startTime)})).sort((a,b)=>a.s-b.s);const wins=[];let cur=ws;for(const b of busy){if(b.s>cur+29)wins.push({s:cur,e:b.s});cur=Math.max(cur,b.e);}if(cur<we-29)wins.push({s:cur,e:we});return wins;}
function hasConflict(ev,all){if(ev.isAllDay||!ev.startTime)return false;const s=toM(ev.startTime),e=toM(ev.endTime||ev.startTime);return all.some(o=>o!==ev&&!o.isAllDay&&o.startTime&&toM(o.startTime)<e&&toM(o.endTime||o.startTime)>s);}

// Schedule
async function renderSchedule(){
  const app=document.getElementById('sched-app');
  app.innerHTML='<div class="loading"><div class="spinner"></div> Pulling calendar…</div>';
  let evts;try{evts=await loadVisibleCals();}catch(e){app.innerHTML=`<div class="err">Could not load calendar.</div>`;return;}
  if(!evts.length){app.innerHTML=`<div class="err">No events found.</div>`;return;}
  const byDate={};for(const ev of evts){if(!byDate[ev.dateStr])byDate[ev.dateStr]=[];byDate[ev.dateStr].push(ev);}
  const firstCal=calendars.find(c=>isVisible(c));
  let html='<div class="sched-wrap">';
  for(const ds of Object.keys(byDate).sort()){
    const evs=byDate[ds],d=new Date(ds+'T12:00:00'),isToday=ds===todayStr;
    evs.sort((a,b)=>{if(a.isAllDay&&!b.isAllDay)return -1;if(!a.isAllDay&&b.isAllDay)return 1;return(a.startTime||'').localeCompare(b.startTime||'');});
    const timed=evs.filter(e=>!e.isAllDay);
    html+=`<div class="day-block"><div class="day-hdr ${isToday?'today':''}"><span class="day-name">${DAYS[d.getDay()]}</span><span class="day-num">${MONTHS[d.getMonth()]} ${d.getDate()}</span>${isToday?'<span class="today-chip">Today</span>':''}</div>`;
    if(isToday){const wins=openWins(evs,firstCal);if(wins.length){html+=`<div class="sec-label">Open windows</div>`;wins.slice(0,3).forEach(w=>{html+=`<div class="win-row">${mts(w.s)} – ${mts(w.e)}<span class="dur">${dur(w.e-w.s)}</span></div>`;});}if(timed.filter(e=>e.type!=='personal').length)html+=`<div class="sec-label" style="margin-top:10px">Meetings</div>`;}
    if(!evs.length)html+=`<div class="no-mtgs">No meetings</div>`;
    for(const ev of evs){
      const ts=ev.isAllDay?'All day':`${fmtT(ev.startTime)}${ev.endTime?' – '+fmtT(ev.endTime):''}`;
      const badge=ev.type==='zoom'?'<span class="badge zoom">Zoom</span>':ev.type==='inperson'?'<span class="badge inperson">In Person</span>':ev.type==='personal'?'<span class="badge personal">Personal</span>':'';
      const loc=ev.zoomUrl?`<div class="evt-loc"><a href="${ev.zoomUrl}" target="_blank">Join Zoom ↗</a></div>`:(ev.location&&!ev.isAllDay?`<div class="evt-loc">${ev.location.length>52?ev.location.slice(0,52)+'…':ev.location}</div>`:'');
      const cf=(!ev.isAllDay&&hasConflict(ev,timed))?`<div class="conflict-flag">⚠ Overlap</div>`:'';
      const dot=calendars.length>1?`<span class="cal-dot" style="background:${ev.calColor}"></span>`:'';
      const borderColor=ev.type==='zoom'?'var(--zoom-fg)':ev.type==='inperson'?'var(--ip-fg)':ev.type==='personal'?'var(--pers-fg)':ev.calColor;
      const eid=encodeURIComponent(JSON.stringify({title:ev.title,dateStr:ev.dateStr,startTime:ev.startTime,endTime:ev.endTime,location:ev.location,zoomUrl:ev.zoomUrl,type:ev.type}));
      html+=`<div class="evt" data-evt="${eid}" onclick="selectEvt(this)" style="border-left-color:${borderColor}"><div class="evt-time ${ev.isAllDay?'allday':''}">${ts}</div><div class="evt-body"><div class="evt-title">${dot}${ev.title}</div>${badge}${cf}${loc}</div></div>`;
    }
    html+='</div>';
  }
  app.innerHTML=html+'</div>';
}
function selectEvt(el){document.querySelectorAll('.evt.selected-evt').forEach(e=>e.classList.remove('selected-evt'));el.classList.add('selected-evt');try{const ev=JSON.parse(decodeURIComponent(el.dataset.evt));showPrepForEvent(ev);}catch(e){}}

// Radar
class ForceGraph{constructor(canvas,nodes,edges,onSel){this.canvas=canvas;this.ctx=canvas.getContext('2d');this.nodes=nodes.map(n=>({...n,x:canvas.width/2+(Math.random()-.5)*220,y:canvas.height/2+(Math.random()-.5)*220,vx:0,vy:0}));this.edges=edges;this.onSel=onSel;this.sel=null;this.drag=null;this.dpr=window.devicePixelRatio||1;this._rsz();window.addEventListener('resize',()=>this._rsz());canvas.addEventListener('click',e=>this._click(e));canvas.addEventListener('mousedown',e=>this._down(e));canvas.addEventListener('mousemove',e=>this._move(e));canvas.addEventListener('mouseup',()=>this.drag=null);canvas.addEventListener('mouseleave',()=>this.drag=null);this._run();}_rsz(){const w=this.canvas.parentElement;this.canvas.width=w.clientWidth*this.dpr;this.canvas.height=w.clientHeight*this.dpr;this.canvas.style.width=w.clientWidth+'px';this.canvas.style.height=w.clientHeight+'px';this.ctx.scale(this.dpr,this.dpr);const c=this.nodes.find(n=>n.id==='center');if(c){c.x=w.clientWidth/2;c.y=w.clientHeight/2;}}_xy(e){const r=this.canvas.getBoundingClientRect();return{x:e.clientX-r.left,y:e.clientY-r.top};}_at(x,y){return this.nodes.find(n=>Math.hypot(n.x-x,n.y-y)<=n.r);}_click(e){const{x,y}=this._xy(e),n=this._at(x,y);this.sel=n?n.id:null;if(this.onSel)this.onSel(n||null);}_down(e){const{x,y}=this._xy(e);this.drag=this._at(x,y)||null;}_move(e){if(!this.drag)return;const{x,y}=this._xy(e);this.drag.x=x;this.drag.y=y;this.drag.vx=0;this.drag.vy=0;}_sim(){const W=this.canvas.width/this.dpr,H=this.canvas.height/this.dpr;for(const n of this.nodes){n.fx=0;n.fy=0;}for(let i=0;i<this.nodes.length;i++)for(let j=i+1;j<this.nodes.length;j++){const a=this.nodes[i],b=this.nodes[j],dx=b.x-a.x,dy=b.y-a.y,d=Math.max(Math.hypot(dx,dy),1),f=7000/(d*d),fx=f*dx/d,fy=f*dy/d;a.fx-=fx;a.fy-=fy;b.fx+=fx;b.fy+=fy;}const nb=Object.fromEntries(this.nodes.map(n=>[n.id,n]));for(const e of this.edges){const a=nb[e.source],b=nb[e.target];if(!a||!b)continue;const dx=b.x-a.x,dy=b.y-a.y,d=Math.max(Math.hypot(dx,dy),1),f=0.04*(d-160),fx=f*dx/d,fy=f*dy/d;a.fx+=fx;a.fy+=fy;b.fx-=fx;b.fy-=fy;}for(const n of this.nodes){if(n.id==='center')continue;n.fx+=(W/2-n.x)*.015;n.fy+=(H/2-n.y)*.015;}const c=nb['center'];if(c){c.x=W/2;c.y=H/2;c.vx=0;c.vy=0;}for(const n of this.nodes){if(n===this.drag)continue;n.vx=(n.vx+n.fx)*.88;n.vy=(n.vy+n.fy)*.88;n.x=Math.max(n.r+8,Math.min(W-n.r-8,n.x+n.vx));n.y=Math.max(n.r+8,Math.min(H-n.r-8,n.y+n.vy));}}_draw(){const ctx=this.ctx,W=this.canvas.width/this.dpr,H=this.canvas.height/this.dpr;ctx.clearRect(0,0,W,H);const nb=Object.fromEntries(this.nodes.map(n=>[n.id,n]));for(const e of this.edges){const a=nb[e.source],b=nb[e.target];if(!a||!b)continue;ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.strokeStyle=`rgba(0,45,116,${Math.min(.08+e.weight*.04,.4)})`;ctx.lineWidth=Math.min(e.weight*.6+.5,4);ctx.stroke();}for(const n of this.nodes){const s=this.sel===n.id;ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fillStyle=s?'#001a49':n.color;ctx.fill();if(s){ctx.strokeStyle='#001a49';ctx.lineWidth=3;ctx.stroke();}const pts=n.label.split(' ');ctx.fillStyle='white';ctx.font=`${n.id==='center'?'bold ':''}${Math.max(9,Math.round(n.r*.48))}px -apple-system,sans-serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(pts[0],n.x,pts[1]&&n.r>20?n.y-Math.round(n.r*.22):n.y);if(pts[1]&&n.r>20){ctx.font=`${Math.max(8,Math.round(n.r*.38))}px -apple-system,sans-serif`;ctx.fillText(pts[1],n.x,n.y+Math.round(n.r*.36));}}}_run(){this._sim();this._draw();requestAnimationFrame(()=>this._run());}}

async function initRadar(){
  if(!features.radar)return;
  const loading=document.getElementById('radar-loading'),panel=document.getElementById('radar-panel'),canvas=document.getElementById('radar-canvas');
  const evts=allEvents.length?allEvents:await loadVisibleCals();
  if(!evts.length){loading.innerHTML=`<div style="color:var(--faint);font-size:12px">No data</div>`;return;}
  const biz=evts.filter(e=>!e.isAllDay&&e.type!=='personal');
  let contacts=[];
  try{const execNames=calendars.map(c=>c.label.split(' ')[0]).join('|');const p=await window.cowork.sample(`From these calendar event titles, extract real people's full names — not (${execNames}). For each: {"name":"Full Name","meetings":N,"type":"internal" or "external"}. Return ONLY valid JSON array, max 9.`,biz.map(e=>e.title));const raw=p.text.match(/\[[\s\S]*?\]/);if(raw)contacts=JSON.parse(raw[0]);}catch(e){}
  if(!contacts.length){const nc={};for(const ev of biz){const pts=ev.title.split(/[\/,&+–\-]|Zoom\s*\||\bwith\b|\band\b/i);for(const p of pts){const c=p.replace(/\b(Weekly|Zoom|Mtg|Meeting|Call|Check.In|Biweekly|Monthly)\b/gi,'').trim();if(c.length>3&&c.length<30&&/^[A-Z]/.test(c)&&!/\d/.test(c))nc[c]=(nc[c]||0)+1;}}contacts=Object.entries(nc).sort((a,b)=>b[1]-a[1]).slice(0,8).map(([name,meetings])=>({name,meetings,type:'internal'}));}
  const colors=['#22438a','#5e5e5e','#1a73e8','#2e7d32','#7b1fa2','#c2410c','#0891b2','#d97706'];
  const center=calendars.find(c=>isVisible(c))?.label||(RIB.ea?.name||'Exec');
  const nodes=[{id:'center',label:center,r:30,color:'#002D74'},...contacts.slice(0,8).map((c,i)=>({id:c.name,label:c.name,r:15+Math.min(c.meetings*3,22),color:colors[i%colors.length],meetings:c.meetings,type:c.type,evts:biz.filter(e=>e.title.toLowerCase().includes(c.name.split(' ')[0].toLowerCase()))}))];
  const edges=contacts.slice(0,8).map(c=>({source:'center',target:c.name,weight:c.meetings}));
  loading.style.display='none';
  new ForceGraph(canvas,nodes,edges,node=>{
    if(!node||node.id==='center'){panel.innerHTML=`<div class="radar-empty">Click a contact<br>to view meeting history</div>`;return;}
    const el=(node.evts||[]).slice(0,5).map(e=>{const d=new Date(e.dateStr+'T12:00:00');return`<div class="mtg-item"><div class="mtg-date">${DAYS[d.getDay()]}, ${MONTHS[d.getMonth()]} ${d.getDate()}${e.startTime?' · '+fmtT(e.startTime):''}</div>${e.title}</div>`;}).join('');
    panel.innerHTML=`<div class="contact-card"><h3>${node.label}</h3><div class="contact-meta">${node.type==='external'?'External':'Internal'}</div><div class="contact-stat"><span class="stat-label">Meetings</span><span class="stat-val">${node.meetings||0}</span></div><div class="contact-stat"><span class="stat-label">Status</span><span class="stat-val">${node.meetings>=5?'Active':node.meetings>=2?'Regular':'Occasional'}</span></div>${el?`<div class="mtg-list"><div class="sec-label" style="margin-bottom:6px">Recent</div>${el}</div>`:''}</div>`;
  });
}

// Prep
let prepEvents=[],selPrep=null;
async function initPrep(){const app=document.getElementById('prep-app');const evts=allEvents.length?allEvents:await loadVisibleCals();prepEvents=evts.filter(e=>!e.isAllDay&&e.type!=='personal'&&e.startTime).slice(0,20);if(!prepEvents.length){app.innerHTML=`<div class="prep-empty">No upcoming business meetings.</div>`;return;}renderPrepList(null);}
function renderPrepList(sel){const app=document.getElementById('prep-app');if(!app)return;const dot=ev=>calendars.length>1?`<span class="cal-dot" style="background:${ev.calColor||'#002D74'}"></span>`:'';const list=prepEvents.map((ev,i)=>{const d=new Date(ev.dateStr+'T12:00:00'),isT=ev.dateStr===todayStr;const lbl=isT?'Today':`${DAYS[d.getDay()]}, ${MONTHS[d.getMonth()]} ${d.getDate()}`;const isSel=sel&&sel.title===ev.title&&sel.dateStr===ev.dateStr;return`<button class="prep-evt-btn ${isSel?'active':''}" onclick="selectPrepEvt(${i})"><div class="prep-evt-title">${dot(ev)}${ev.title}</div><div class="prep-evt-time">${lbl} · ${fmtT(ev.startTime)}${ev.endTime?' – '+fmtT(ev.endTime):''}</div></button>`;}).join('');const detail=sel?renderPrepDetail(sel):`<div class="prep-empty">Select a meeting<br>to see prep notes</div>`;app.innerHTML=`<div class="prep-upcoming"><h4>Upcoming meetings</h4>${list}</div>${detail}`;}
function renderPrepDetail(ev){const d=new Date(ev.dateStr+'T12:00:00');const loc=ev.zoomUrl?`<a href="${ev.zoomUrl}" target="_blank" style="color:var(--zoom-fg)">Join Zoom ↗</a>`:(ev.location||'TBD');return`<div class="prep-card"><h3>${ev.title}</h3><div class="prep-row"><span class="prep-label">Date</span>${DAYS[d.getDay()]}, ${MONTHS[d.getMonth()]} ${d.getDate()}</div><div class="prep-row"><span class="prep-label">Time</span>${fmtT(ev.startTime)}${ev.endTime?' – '+fmtT(ev.endTime):''} PT</div><div class="prep-row"><span class="prep-label">Format</span>${loc}</div></div><div id="prep-ai-notes"><div class="loading" style="height:70px"><div class="spinner"></div> Generating notes…</div></div>`;}
function selectPrepEvt(i){selPrep=prepEvents[i];renderPrepList(selPrep);genPrepNotes(selPrep);}
async function genPrepNotes(ev){
  const el=document.getElementById('prep-ai-notes');if(!el)return;
  try{
    // Extract meaningful search terms (strip generic words, keep names/companies)
    const searchQ=ev.title
      .replace(/\b(Zoom|Weekly|Biweekly|Monthly|Check.?In|Call|Meeting|Mtg|Debrief|Sync|Update|Review|Kickoff|Intro|Virtual)\b/gi,'')
      .replace(/[\/|:–\-]/g,' ').replace(/\s+/g,' ').trim()
      .split(' ').filter(w=>w.length>3).slice(0,4).join(' ');

    // Pull relevant emails from the viewer's inbox (their own Outlook account)
    let emailCtx='';
    if(searchQ){
      try{
        const eRes=await window.cowork.callMcpTool(SEARCH_EMAILS,{accountId:'me',query:searchQ,count:5});
        if(!eRes.isError&&eRes.content[0]?.text){
          const lines=eRes.content[0].text.split('\n')
            .filter(l=>/Subject:|From:|Date:/.test(l)).slice(0,9).join(' | ');
          if(lines)emailCtx='Recent emails: '+lines;
        }
      }catch(e){}
    }

    // Prior calendar touchpoints with same people/topic
    const calCtx=allEvents
      .filter(e=>e.title.toLowerCase().includes((ev.title.split(/[\/,]/)[0]||'').trim().toLowerCase().slice(0,8))&&e.dateStr!==ev.dateStr)
      .slice(0,4).map(e=>`${e.dateStr}: ${e.title}`).join('; ');

    const ctx=[calCtx&&`Prior meetings: ${calCtx}`,emailCtx].filter(Boolean).join('\n');

    // Viewer-aware prompt: EA managing exec vs exec viewing own calendar
    const role=viewer==='exec'
      ?'the executive attending this meeting'
      :'an executive assistant preparing their exec for this meeting';

    const r=await window.cowork.sample(
      `Generate meeting prep notes for ${role}. Write 2-3 specific, actionable bullet points:
- What to confirm or prepare beforehand (materials, attendees, agenda)
- One logistical detail to have ready (dial-in link, location, who's joining)
- One smart question or talking point worth raising

Be specific to this meeting — avoid generic advice. Under 90 words.

Meeting: "${ev.title}"
Date: ${ev.dateStr} at ${ev.startTime||'TBD'} PT
Format: ${ev.location||'TBD'}
${ctx}`,
      []
    );

    if(el&&!r.isError){
      const bullets=r.text.split('\n').filter(l=>l.trim())
        .map(l=>`<li style="margin-bottom:5px">${l.replace(/^[-•*\d.]\s*/,'')}</li>`).join('');
      el.innerHTML=`<div class="prep-card"><div class="sec-label" style="margin-bottom:6px">Prep notes</div><ul style="padding-left:16px;font-size:12px;line-height:1.6">${bullets}</ul></div>`;
    }
  }catch(e){if(el)el.innerHTML='';}
}
function showPrepForEvent(ev){if(ev.type==='personal'||ev.isAllDay)return;selPrep=ev;switchTab('prep');if(!prepInited){prepInited=true;initPrep().then(()=>{selPrep=ev;renderPrepList(ev);genPrepNotes(ev);});}else{renderPrepList(ev);genPrepNotes(ev);}}

// Init
renderSchedule();
if(activeTab==='radar')initRadar();
if(activeTab==='prep')initPrep();
</script>
